{
    "name": "Ansible Home Lab",
    "image": "mcr.microsoft.com/devcontainers/base:fedora",
    "customizations": {
        "vscode": {
            "extensions": [
                "redhat.ansible",
                "ms-vscode-remote.remote-containers"
            ]
        }
    },
    "mounts": [
        "source=${localWorkspaceFolder},target=/workspace,type=bind,Z"
    ],
    "remoteUser": "vscode"
}

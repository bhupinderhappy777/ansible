{
    "name": "Ansible & DevOps Environment",
    "image": "registry.fedoraproject.org/fedora:41",
    "runArgs": [
        "--hostname=ansible-lab",
        "--security-opt=label=disable",
        "--privileged"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "redhat.ansible",
                "redhat.vscode-yaml",
                "ms-azuretools.vscode-docker"
            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "zsh",
                "ansible.ansible.path": "/usr/local/bin/ansible",
                "ansible.python.interpreterPath": "/usr/bin/python3",
                "ansible.ansible-lint.path": "/usr/local/bin/ansible-lint",
                "ansible.validation.lint.path": "/usr/local/bin/ansible-lint"
            }
        }
    },
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/ansible,type=bind",
    "workspaceFolder": "/workspaces/ansible",
    "remoteUser": "root",
    "onCreateCommand": "dnf install -y git openssh-clients python3-pip && pip install ansible ansible-lint",
    "shutdownAction": "stopContainer"
}
